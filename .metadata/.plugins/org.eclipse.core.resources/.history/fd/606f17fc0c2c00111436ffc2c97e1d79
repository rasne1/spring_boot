<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.members.dao.MembersDao">

  <insert id="insertNewMembers" 
  parameterType="com.ktdsuniversity.edu.members.vo.request.MembersVO">
  INSERT INTO MEMBERS
     (EMAIL
     , NAME
     , PASSWORD)
     VALUES
     (#{email}
     , #{name}
     , #{password})
  </insert>
  
    
   
  <select id="selectMemberList" 
  resultType="com.ktdsuniversity.edu.members.vo.request.MembersVO">
  SELECT EMAIL
       , NAME
       , PASSWORD
    FROM MEMBERS
  </select>
  
  <select id="selectMemberCount" resultType="_int">
  SELECT COUNT(EMAIL)
    FROM MEMBERS
  </select>
  
  <select id="findMemberByEmail" resultType="com.ktdsuniversity.edu.members.vo.request.MembersVO">
  SELECT EMAIL
     , NAME
     , PASSWORD
  FROM MEMBERS
 WHERE EMAIL = #{_parameter}
  </select>
  
  
  
  
  <update id="updateMemberByEmail" parameterType="com.ktdsuniversity.edu.members.vo.request.MemberUpdateVO">
  UPDATE MEMBERS
     SET NAME=#{name}
       , PASSWORD=#{password}
     WHERE EMAIL=#{email}
  </update>
  
</mapper>