<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.members.dao.MembersDao">

  <insert id="insertNewMembers" 
  parameterType="com.ktdsuniversity.edu.members.vo.request.MembersVO">
  INSERT INTO MEMBERS
     (EMAIL
     , NAME
     , PASSWORD)
     VALUES
     (#{email}
     , #{name}
     , #{password})
  </insert>
  
  MembersVO selectBoardById(String id);
  <select id="selectBoardById" 
  resultType="com.ktdsuniversity.edu.members.vo.request.MembersVO"
  parameterType="string">
  SELECT EMAIL
       , NAME
       , PASSWORD
    FROM MEMBERS
   WHERE ID = #{_parameter}
  </select>
  
</mapper>